{
  "name": "go-ddd-template",
  "version": "1.0.0-d",
  "description": "TypeScript SDK for Go DDD Template API",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "convert": "swagger2openapi ../docs/swagger.json -o ./temp-openapi.yaml && openapi-typescript ./temp-openapi.yaml --output ./src/api.d.ts && rm ./temp-openapi.yaml",
    "generate": "npm run convert",
    "build": "tsc --noEmit"
  },
  "keywords": [
    "api",
    "sdk",
    "openapi",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "openapi-fetch": "^0.10.0",
    "openapi-typescript": "^7.0.0",
    "swagger2openapi": "^7.0.0",
    "typescript": "^5.3.0"
  }
}
