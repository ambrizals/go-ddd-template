{
  "name": "@ambrizals/go-ddd-template",
  "version": "1.0.3",
  "description": "TypeScript SDK for Go DDD Template API",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/ambrizals/go-ddd-template.git"
  },
  "scripts": {
    "convert": "swagger2openapi ../docs/swagger.json -o ./temp-openapi.yaml && openapi-typescript ./temp-openapi.yaml --output ./src/api.d.ts && rm ./temp-openapi.yaml",
    "generate:types": "npm run convert",
    "generate:client": "bun ./scripts/generate-client.ts",
    "generate": "npm run generate:types && npm run generate:client",
    "build": "tsc --noEmit"
  },
  "keywords": [
    "api",
    "sdk",
    "openapi",
    "typescript"
  ],
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "bun": ">=1.2.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "openapi-fetch": "^0.10.0",
    "openapi-typescript": "^7.0.0",
    "swagger2openapi": "^7.0.0",
    "typescript": "^5.3.0"
  }
}
